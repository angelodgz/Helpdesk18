<odoo>
    <record id="view_helpdesk_refuse_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.refuse.wizard.form</field>
        <field name="model">helpdesk.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Ticket">
                <sheet>
                    <group>
                        <field name="ticket_id" readonly="1"/>
                        <field name="refused_reason" options="{'no_open': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Refuse" type="object" name="action_confirm_refusal" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
