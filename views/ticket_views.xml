<odoo>
    <record id="view_helpdesk_ticket_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.list</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority=='3'"
                  decoration-warning="priority=='2'"
                  decoration-success="state=='approved'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="category"/>
                <field name="priority"/>
                <field name="stage_id"/>        
                <field name="assigned_to"/>     
                <field name="date_requested"/>  
                <field name="state"/> 
            </list>
        </field>
    </record>

    
<record id="view_helpdesk_ticket_form" model="ir.ui.view">
    <field name="name">helpdesk.ticket.form</field>
    <field name="model">helpdesk.ticket</field>
    <field name="arch" type="xml">
        <form>

            <!-- STATUS BAR -->
            <header>
                <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,in_review,approved,refused"/>
                
                <!-- ACTION BUTTONS -->
                <button name="action_mark_done" string="Mark as Done" type="object" class="oe_highlight"
                        invisible="state != 'draft'"/>
                <button name="action_approve" string="Approve" type="object" class="oe_highlight"
                        invisible="state != 'in_review'"
                        groups="helpdesk_ticket.group_helpdesk_manager"/>
                <button name="action_refuse" string="Refuse" type="object"
                        invisible="state != 'in_review'"
                        groups="helpdesk_ticket.group_helpdesk_manager"/>
                <button name="action_reopen" string="Reopen" type="object"
                        invisible="state != 'refused'"/>
            </header>

            <sheet>


                <!-- MAIN FIELDS -->
                <group>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="category"/>
                        <field name="priority" widget="priority"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="stage_id"/>
                        <field name="assigned_to"/>
                        <field name="date_requested"/>
                        <field name="date_closed"/>
                        <field name="approved_by" readonly="1"/>
                    </group>
                </group>

                <!-- DESCRIPTION -->
                <group string="Description">
                    <field name="description" nolabel="1"/>
                </group>

                <!-- DYNAMIC FIELDS PER CATEGORY -->

                <!-- IT Support -->
                <group string="IT Support Details" invisible="category != 'it'">
                    <group>
                        <field name="issue_type"/>
                        <field name="urgency"/>
                    </group>
                    <group>
                        <field name="device_tag"/>
                        <field name="affected_system"/>
                    </group>
                </group>

                <!-- HR Request -->
                <group string="HR Request Details" invisible="category != 'hr'">
                    <group>
                        <field name="request_type"/>
                        <field name="effective_date"/>
                    </group>
                    <group>
                        <field name="hr_notes"/>
                    </group>
                </group>

                <!-- Facilities -->
                <group string="Facilities Details" invisible="category != 'facilities'">
                    <group>
                        <field name="location"/>
                        <field name="facility_type"/>
                    </group>
                    <group>
                        <field name="estimated_cost"/>
                    </group>
                </group>

                <!-- Finance -->
                <group string="Finance Details" invisible="category != 'finance'">
                    <group>
                        <field name="amount"/>
                        <field name="payment_mode"/>
                    </group>
                    <group>
                        <field name="expected_liquidation_date"/>
                    </group>
                </group>

                <!-- REFUSED REASON -->
                <group string="Refused Reason" invisible="state != 'refused'">
                    <field name="refused_reason" nolabel="1" readonly="1"/>
                </group>

                <!-- ATTACHMENTS -->
                <group string="Attachments">
                    <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                </group>

            </sheet>

            <!-- CHATTER -->
            <chatter/>

        </form>
    </field>
</record>
<record id="view_helpdesk_ticket_calendar" model="ir.ui.view">
    <field name="name">helpdesk.ticket.calendar</field>
    <field name="model">helpdesk.ticket</field>
    <field name="arch" type="xml">
        <calendar date_start="date_requested" color="priority" mode="month">
            <field name="name"/>
            <field name="employee_id"/>
        </calendar>
    </field>
</record>
</odoo>