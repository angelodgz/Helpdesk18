<odoo>
 <!-- Helpdesk Ticket Stages dito naman yung progress stages ng ticket -->
    <data noupdate="0">
        <record id="stage_new" model="helpdesk.ticket.stage">
            <field name="name">New</field>
            <field name="sequence">1</field>
        </record>
        <record id="stage_in_progress" model="helpdesk.ticket.stage">
            <field name="name">In Progress</field>
            <field name="sequence">2</field>
        </record>
        <record id="stage_for_approval" model="helpdesk.ticket.stage">
            <field name="name">For Approval</field>
            <field name="sequence">3</field>
        </record>
        <record id="stage_done" model="helpdesk.ticket.stage">
            <field name="name">Done</field>
            <field name="sequence">4</field>
            <field name="is_done_stage">True</field>
        </record>
        <record id="stage_cancelled" model="helpdesk.ticket.stage">
            <field name="name">Cancelled</field>
            <field name="sequence">5</field>
            <field name="is_cancelled_stage">True</field>
            <field name="fold">True</field>
        </record>
        <record id="stage_rejected" model="helpdesk.ticket.stage">
            <field name="name">Approval Rejected</field>
            <field name="sequence">6</field>
        </record>
    </data>
</odoo>