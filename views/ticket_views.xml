<odoo>
    <!-- Search View -->
    <record id="view_helpdesk_ticket_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search string="Search Tickets">

                <!-- Search Fields -->
                <field name="name" string="Ticket" />
                <field name="employee_id" string="Employee" />
                <field name="assigned_to" string="Assigned To" />
                <field name="category" string="Category" />

                <!-- FILTERS -->
                <filter
                    name="my_tickets"
                    string="My Tickets"
                    domain="[('employee_id.user_id', '=', uid)]" />

                <filter
                    name="waiting_approval"
                    string="Waiting Approval"
                    domain="[('state', '=', 'in_review')]" />

                <filter
                    name="high_priority"
                    string="High Priority"
                    domain="[('priority', 'in', ['2', '3'])]" />

                <filter
                    name="overdue"
                    string="Overdue"
                    domain="[('date_closed', '=', False), ('date_requested', '&lt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d %H:%M:%S'))]" />

                <filter
                    name="done"
                    string="Done"
                    domain="[('stage_id.is_done_stage', '=', True)]" />

                <filter
                    name="cancelled"
                    string="Cancelled"
                    domain="[('stage_id.is_cancelled_stage', '=', True)]" />

                <separator />

                <!-- GROUP BY -->
                <group expand="0" string="Group By">
                    <filter
                        name="group_category"
                        string="Category"
                        context="{'group_by': 'category'}" />
                    <filter
                        name="group_priority"
                        string="Priority"
                        context="{'group_by': 'priority'}" />
                    <filter
                        name="group_stage"
                        string="Stage"
                        context="{'group_by': 'stage_id'}" />
                    <filter
                        name="group_assigned"
                        string="Assigned To"
                        context="{'group_by': 'assigned_to'}" />
                    <filter
                        name="group_date_week"
                        string="Date Requested (Week)"
                        context="{'group_by': 'date_requested:week'}" />
                    <filter
                        name="group_date_month"
                        string="Date Requested (Month)"
                        context="{'group_by': 'date_requested:month'}" />
                </group>

            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="view_helpdesk_ticket_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.list</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority=='3'"
                decoration-warning="priority=='2'"
                decoration-success="state=='approved'">
                <field name="name" />
                <field name="employee_id" />
                <field name="category" />
                <field name="priority" />
                <field name="stage_id" />
                <field name="assigned_to" />
                <field name="date_requested" />
                <field name="state" />
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_helpdesk_ticket_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form>

                <!-- STATUS BAR -->
                <header>
                    <button name="action_mark_done"
                        string="Mark as Done"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft'" />

                    <button name="action_approve"
                        string="Approve"
                        type="object"
                        class="oe_highlight"
                        groups="helpdesk_ticket.group_helpdesk_manager"
                        invisible="state != 'in_review'" />

                    <button name="action_refuse"
                        string="Refuse"
                        type="object"
                        class="btn-danger"
                        groups="helpdesk_ticket.group_helpdesk_manager"
                        invisible="state != 'in_review'" />

                    <button name="action_reopen"
                        string="Reopen"
                        type="object"
                        invisible="state != 'refused'" />

                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}" />
                </header>

                <sheet>
                    <!-- MAIN FIELDS -->
                    <widget name="web_ribbon" title="Done" bg_color="text-bg-success"
                        invisible="not is_done_stage" />
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger"
                        invisible="not is_cancelled_stage" />
                    <group>
                        <group>
                            <field name="name" readonly="1" placeholder="TKT-0000" />
                            <field name="employee_id" />
                            <field name="category" />
                            <field name="priority" widget="priority" />
                            <field name="tag_ids" widget="many2many_tags"
                                options="{'color_field': 'color', 'no_create_edit': True}" />
                        </group>
                        <group>
                            <field name="stage_id" />
                            <field name="assigned_to" />
                            <field name="date_requested" />
                            <field name="date_closed" />
                            <field name="approved_by" readonly="1" />
                        </group>
                    </group>
                    <!-- DESCRIPTION -->
                    <group string="Description">
                        <field name="description" nolabel="1" />
                    </group>
                    <!-- DYNAMIC FIELDS PER CATEGORY -->
                    <!-- IT Support -->
                    <group string="IT Support Details" invisible="category != 'it'">
                        <group>
                            <field name="issue_type" />
                            <field name="urgency" />
                        </group>
                        <group>
                            <field name="device_tag" />
                            <field name="affected_system" />
                        </group>
                    </group>
                    <!-- HR Request -->
                    <group string="HR Request Details" invisible="category != 'hr'">
                        <group>
                            <field name="request_type" />
                            <field name="effective_date" />
                        </group>
                        <group>
                            <field name="hr_notes" />
                        </group>
                    </group>
                    <!-- Facilities -->
                    <group string="Facilities Details" invisible="category != 'facilities'">
                        <group>
                            <field name="location" />
                            <field name="facility_type" />
                        </group>
                        <group>
                            <field name="estimated_cost" widget="numeric_tolerance" />
                        </group>
                    </group>
                    <!-- Finance -->
                    <group string="Finance Details" invisible="category != 'finance'">
                        <group>
                            <field name="amount" />
                            <field name="payment_mode" />
                        </group>
                        <group>
                            <field name="expected_liquidation_date" />
                        </group>
                    </group>
                    <!-- REFUSED REASON -->
                    <group string="Refused Reason" invisible="state != 'refused'">
                        <field name="refused_reason" nolabel="1" readonly="1" />
                    </group>
                    <!-- ATTACHMENTS -->
                    <group string="Attachments">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1" />
                    </group>

                </sheet>
                <!-- CHATTER -->
                <chatter />

            </form>
        </field>
    </record>
    <!-- Calendar View -->
    <record id="view_helpdesk_ticket_calendar" model="ir.ui.view">
        <field name="name">helpdesk.ticket.calendar</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <calendar date_start="date_requested" color="priority" mode="month">
                <field name="name" />
                <field name="employee_id" />
            </calendar>
        </field>
    </record>

    <!-- Kanban View for Managers -->
    <record id="helpdesk_ticket_view_kanban" model="ir.ui.view">
        <field name="name">helpdesk.ticket.kanban</field>
        <field name="model">helpdesk.ticket</field>
        <field name="priority">1</field>
        <field name="groups_id" eval="[(4, ref('helpdesk_ticket.group_helpdesk_manager'))]" />
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" quick_create="true">
                <field name="stage_id" />
                <field name="color" />
                <field name="is_done_stage" />
                <field name="is_cancelled_stage" />
                <field name="employee_id" />
                <field name="category" />

                <templates>
                    <t t-name="kanban-box">
                        <div
                            t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="name" />
                                    </strong>
                                    <span t-if="record.is_done_stage.raw_value"
                                        class="badge rounded-pill text-bg-success float-end">Done</span>
                                    <span t-if="record.is_cancelled_stage.raw_value"
                                        class="badge rounded-pill text-bg-danger float-end">
                                        Cancelled</span>
                                </div>
                                <field name="priority" widget="priority" />
                                <div>
                                    <field name="employee_id" />
                                </div>
                                <div>
                                    <field name="category" />
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Graph View -->
    <record id="view_helpdesk_ticket_graph" model="ir.ui.view">
        <field name="name">helpdesk.ticket.graph</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <graph string="Ticket Trends" type="bar">
                <field name="category" type="row" />
                <field name="stage_id" type="col" />
            </graph>
        </field>
    </record>
</odoo>