<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Stage list view ──────────────────────────────────────────────── -->
    <record id="view_helpdesk_stage_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.stage.list</field>
        <field name="model">helpdesk.ticket.stage</field>
        <field name="arch" type="xml">
            <list string="Stages" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_done_stage"/>
                <field name="is_cancelled_stage"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <!-- ── Stage form view ──────────────────────────────────────────────── -->
    <record id="view_helpdesk_stage_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.stage.form</field>
        <field name="model">helpdesk.ticket.stage</field>
        <field name="arch" type="xml">
            <form string="Stage">
                <sheet>
                    <!-- Ribbon: Done Stage -->
                    <widget name="web_ribbon"
                            title="Done Stage"
                            bg_color="text-bg-success"
                            invisible="not is_done_stage"/>

                    <!-- Ribbon: Cancelled Stage -->
                    <widget name="web_ribbon"
                            title="Cancelled Stage"
                            bg_color="text-bg-danger"
                            invisible="not is_cancelled_stage"/>

                    <group>
                        <group string="Stage Details">
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="fold"/>
                        </group>
                        <group string="Stage Type Flags">
                            <field name="is_done_stage"/>
                            <field name="is_cancelled_stage"/>
                            <field name="is_approval_stage"/>
                        </group>
                    </group>
                    <group string="Internal Notes">
                        <field name="description" nolabel="1" placeholder="Optional notes about what this stage means…"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
