<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_refuse_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.refuse.wizard.form</field>
        <field name="model">helpdesk.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Reason">
                <group>
                    <field name="refused_reason" placeholder="Enter reason for refusal..."/>
                </group>
                <footer>
                    <button name="action_confirm_refusal" string="Confirm" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_refuse_wizard" model="ir.actions.act_window">
        <field name="name">Refuse Ticket</field>
        <field name="res_model">helpdesk.refuse.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>