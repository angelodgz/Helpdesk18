<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_helpdesk_inherit" model="ir.ui.view">
        <field name="name">hr.employee.helpdesk.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">

                <!-- Smart Button 1: Tickets submitted by this employee -->
                <button name="action_view_helpdesk_tickets"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-life-ring">
                    <field name="helpdesk_ticket_count"
                           widget="statinfo"
                           string="Tickets Submitted"/>
                </button>

                <!-- Bonus Smart Button 2: Tickets assigned to this employee as agent -->
                <button name="action_view_assigned_helpdesk_tickets"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tasks">
                    <field name="helpdesk_assigned_ticket_count"
                           widget="statinfo"
                           string="Tickets Assigned"/>
                </button>

            </xpath>
        </field>
    </record>
</odoo>
