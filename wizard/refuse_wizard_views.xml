<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_refuse_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.refuse.wizard.form</field>
        <field name="model">helpdesk.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Ticket">
                <group>
                    <field name="ticket_id" readonly="1"/>
                    <field name="refused_reason"
                           placeholder="Enter a clear reason for refusing this ticket…"
                           nolabel="1"
                           rows="4"/>
                </group>
                <footer>
                    <button name="action_confirm_refusal"
                            string="Confirm Refusal"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
